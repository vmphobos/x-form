{
    "name": "vmphobos/x-form",
    "description": "X-Form Blade Components for Livewire 3. Rapidly build forms with customizable one line inputs.",
    "license": "MIT",
    "authors": [
        {
            "name": "Vasilis Milopoulos",
            "email": "kevinsunrayofficial@gmail.com",
            "homepage": "https://github.com/vmphobos"
        }
    ],
    "homepage": "https://www.kevinsunray.com",
    "keywords": [
        "Laravel",
        "Livewire",
        "Blade",
        "Components",
        "UI",
        "XForm",
        "x-form",
        "form",
        "forms",
        "form-builder",
        "form-components",
        "laravel-form-builder",
        "laravel-form-components",
        "bootstrap",
        "bootstrap4",
        "bootstrap5",
        "bootstrap-4",
        "bootstrap-5"
    ],
    "require": {
        "php": "^8.1 || ^8.2",
        "livewire/livewire": "^3.0",
        "illuminate/support": "~10"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.2"
    },
    "autoload": {
        "psr-4": {
            "XForm\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "XForm\\XFormServiceProvider"
            ],
            "aliases": {
                "XForm": "XForm\\Facades\\XForm"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
